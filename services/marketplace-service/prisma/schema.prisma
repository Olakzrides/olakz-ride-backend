generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model MarketplaceCategory {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String   @db.VarChar(100)
  description String?
  iconUrl     String?  @map("icon_url")
  isActive    Boolean  @default(true) @map("is_active")
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  storeCategories MarketplaceStoreCategory[]
  products        MarketplaceProduct[]

  @@map("marketplace_categories")
}

model MarketplaceStore {
  id                   String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ownerId              String   @unique @map("owner_id") @db.Uuid
  vendorId             String?  @map("vendor_id") @db.Uuid
  name                 String   @db.VarChar(200)
  description          String?
  logoUrl              String?  @map("logo_url")
  bannerUrl            String?  @map("banner_url")
  address              String
  city                 String?  @db.VarChar(100)
  state                String?  @db.VarChar(100)
  latitude             Decimal  @db.Decimal(10, 8)
  longitude            Decimal  @db.Decimal(11, 8)
  phone                String?  @db.VarChar(20)
  email                String?  @db.VarChar(255)
  isActive             Boolean  @default(true) @map("is_active")
  isOpen               Boolean  @default(false) @map("is_open")
  isVerified           Boolean  @default(false) @map("is_verified")
  averageRating        Decimal  @default(0.00) @map("average_rating") @db.Decimal(3, 2)
  totalRatings         Int      @default(0) @map("total_ratings")
  totalOrders          Int      @default(0) @map("total_orders")
  operatingHours       Json     @default("{}") @map("operating_hours")
  createdAt            DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt            DateTime @updatedAt @map("updated_at") @db.Timestamptz

  storeCategories MarketplaceStoreCategory[]
  products        MarketplaceProduct[]
  carts           MarketplaceCart[]
  orders          MarketplaceOrder[]
  reviews         MarketplaceReview[]

  @@map("marketplace_stores")
}

model MarketplaceStoreCategory {
  storeId    String              @map("store_id") @db.Uuid
  categoryId String              @map("category_id") @db.Uuid
  store      MarketplaceStore    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  category   MarketplaceCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([storeId, categoryId])
  @@map("marketplace_store_categories")
}

model MarketplaceProduct {
  id            String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  storeId       String              @map("store_id") @db.Uuid
  categoryId    String?             @map("category_id") @db.Uuid
  name          String              @db.VarChar(200)
  description   String?
  price         Decimal             @db.Decimal(10, 2)
  images        String[]            @default([])
  isActive      Boolean             @default(true) @map("is_active")
  isAvailable   Boolean             @default(true) @map("is_available")
  stockQuantity Int?                @map("stock_quantity")
  averageRating Decimal             @default(0.00) @map("average_rating") @db.Decimal(3, 2)
  totalRatings  Int                 @default(0) @map("total_ratings")
  createdAt     DateTime            @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime            @updatedAt @map("updated_at") @db.Timestamptz
  store         MarketplaceStore    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  category      MarketplaceCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  cartItems     MarketplaceCartItem[]
  orderItems    MarketplaceOrderItem[]
  productReviews MarketplaceProductReview[]
  wishlistItems  MarketplaceWishlist[]

  @@map("marketplace_products")
}

model MarketplaceFareConfig {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  vehicleType        String   @unique @map("vehicle_type") @db.VarChar(50)
  pricePerKm         Decimal  @map("price_per_km") @db.Decimal(10, 2)
  minimumDeliveryFee Decimal  @map("minimum_delivery_fee") @db.Decimal(10, 2)
  serviceFee         Decimal  @default(0.00) @map("service_fee") @db.Decimal(10, 2)
  currencyCode       String   @default("NGN") @map("currency_code") @db.VarChar(10)
  isActive           Boolean  @default(true) @map("is_active")
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@map("marketplace_fare_config")
}

model MarketplaceCart {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  storeId   String   @map("store_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz
  store     MarketplaceStore @relation(fields: [storeId], references: [id], onDelete: Cascade)
  items     MarketplaceCartItem[]

  @@unique([userId, storeId])
  @@map("marketplace_carts")
}

model MarketplaceCartItem {
  id        String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cartId    String             @map("cart_id") @db.Uuid
  productId String             @map("product_id") @db.Uuid
  quantity  Int                @default(1)
  unitPrice Decimal            @map("unit_price") @db.Decimal(10, 2)
  createdAt DateTime           @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime           @updatedAt @map("updated_at") @db.Timestamptz
  cart      MarketplaceCart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product   MarketplaceProduct @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("marketplace_cart_items")
}

model MarketplaceSavedAddress {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  label     String   @db.VarChar(50)
  address   String
  city      String?  @db.VarChar(100)
  state     String?  @db.VarChar(100)
  latitude  Decimal? @db.Decimal(10, 8)
  longitude Decimal? @db.Decimal(11, 8)
  isDefault Boolean  @default(false) @map("is_default")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@map("marketplace_saved_addresses")
}

model MarketplaceOrder {
  id                   String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customerId           String   @map("customer_id") @db.Uuid
  storeId              String   @map("store_id") @db.Uuid
  riderId              String?  @map("rider_id") @db.Uuid
  status               String   @default("pending") @db.VarChar(50)
  paymentMethod        String   @default("wallet") @map("payment_method") @db.VarChar(20)
  paymentStatus        String   @default("pending") @map("payment_status") @db.VarChar(20)
  subtotal             Decimal  @db.Decimal(10, 2)
  deliveryFee          Decimal  @default(0.00) @map("delivery_fee") @db.Decimal(10, 2)
  serviceFee           Decimal  @default(0.00) @map("service_fee") @db.Decimal(10, 2)
  totalAmount          Decimal  @map("total_amount") @db.Decimal(10, 2)
  deliveryAddress      Json     @map("delivery_address")
  specialInstructions  String?  @map("special_instructions")
  walletTransactionId  String?  @map("wallet_transaction_id")
  walletBalanceBefore  Decimal? @map("wallet_balance_before") @db.Decimal(10, 2)
  walletBalanceAfter   Decimal? @map("wallet_balance_after") @db.Decimal(10, 2)
  cancellationReason   String?  @map("cancellation_reason")
  cancelledBy          String?  @map("cancelled_by") @db.VarChar(20)
  rejectionReason      String?  @map("rejection_reason")
  excludedRiderIds     String[] @default([]) @map("excluded_rider_ids") @db.Uuid
  riderSearchAttempts  Int      @default(0) @map("rider_search_attempts")
  acceptedAt           DateTime? @map("accepted_at") @db.Timestamptz
  readyAt              DateTime? @map("ready_at") @db.Timestamptz
  shippedAt            DateTime? @map("shipped_at") @db.Timestamptz
  arrivedAt            DateTime? @map("arrived_at") @db.Timestamptz
  deliveredAt          DateTime? @map("delivered_at") @db.Timestamptz
  cancelledAt          DateTime? @map("cancelled_at") @db.Timestamptz
  createdAt            DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt            DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  store                MarketplaceStore @relation(fields: [storeId], references: [id])
  orderItems           MarketplaceOrderItem[]
  statusHistory        MarketplaceOrderStatusHistory[]
  riderAssignments     MarketplaceRiderAssignment[]
  riderLocations       MarketplaceRiderLocation[]
  riderEarnings        MarketplaceRiderEarning[]

  @@map("marketplace_orders")
}

model MarketplaceOrderItem {
  id           String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId      String             @map("order_id") @db.Uuid
  productId    String             @map("product_id") @db.Uuid
  productName  String             @map("product_name") @db.VarChar(200)
  productPrice Decimal            @map("product_price") @db.Decimal(10, 2)
  quantity     Int                @default(1)
  subtotal     Decimal            @db.Decimal(10, 2)
  order        MarketplaceOrder   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product      MarketplaceProduct @relation(fields: [productId], references: [id])

  @@map("marketplace_order_items")
}

model MarketplaceOrderStatusHistory {
  id             String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId        String           @map("order_id") @db.Uuid
  status         String           @db.VarChar(50)
  previousStatus String?          @map("previous_status") @db.VarChar(50)
  changedBy      String?          @map("changed_by") @db.Uuid
  changedByRole  String?          @map("changed_by_role") @db.VarChar(20)
  notes          String?
  createdAt      DateTime         @default(now()) @map("created_at") @db.Timestamptz
  order          MarketplaceOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("marketplace_order_status_history")
}

model MarketplaceRiderAssignment {
  id                 String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId            String           @map("order_id") @db.Uuid
  riderId            String           @map("rider_id") @db.Uuid
  status             String           @default("assigned") @db.VarChar(50)
  cancelledAt        DateTime?        @map("cancelled_at") @db.Timestamptz
  cancellationReason String?          @map("cancellation_reason")
  createdAt          DateTime         @default(now()) @map("created_at") @db.Timestamptz
  order              MarketplaceOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("marketplace_rider_assignments")
}

model MarketplaceRiderLocation {
  id        String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId   String           @map("order_id") @db.Uuid
  riderId   String           @map("rider_id") @db.Uuid
  latitude  Decimal          @db.Decimal(10, 8)
  longitude Decimal          @db.Decimal(11, 8)
  heading   Decimal?         @db.Decimal(5, 2)
  speed     Decimal?         @db.Decimal(6, 2)
  createdAt DateTime         @default(now()) @map("created_at") @db.Timestamptz
  order     MarketplaceOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("marketplace_rider_locations")
}

model MarketplaceRiderEarning {
  id          String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  riderId     String           @map("rider_id") @db.Uuid
  orderId     String           @map("order_id") @db.Uuid
  deliveryFee Decimal          @map("delivery_fee") @db.Decimal(10, 2)
  totalEarned Decimal          @map("total_earned") @db.Decimal(10, 2)
  status      String           @default("pending") @db.VarChar(20)
  createdAt   DateTime         @default(now()) @map("created_at") @db.Timestamptz
  order       MarketplaceOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("marketplace_rider_earnings")
}

model MarketplaceReview {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId    String   @unique @map("order_id") @db.Uuid
  customerId String   @map("customer_id") @db.Uuid
  storeId    String   @map("store_id") @db.Uuid
  storeRating Int     @map("store_rating")
  comment    String?
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz
  store      MarketplaceStore @relation(fields: [storeId], references: [id], onDelete: Cascade)
  productReviews MarketplaceProductReview[]

  @@map("marketplace_reviews")
}

model MarketplaceProductReview {
  id            String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  reviewId      String             @map("review_id") @db.Uuid
  productId     String             @map("product_id") @db.Uuid
  productRating Int                @map("product_rating")
  review        MarketplaceReview  @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  product       MarketplaceProduct @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("marketplace_product_reviews")
}

model MarketplaceWishlist {
  id        String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String             @map("user_id") @db.Uuid
  productId String             @map("product_id") @db.Uuid
  createdAt DateTime           @default(now()) @map("created_at") @db.Timestamptz
  product   MarketplaceProduct @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@map("marketplace_wishlist")
}
